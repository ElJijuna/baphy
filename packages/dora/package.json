{
  "name": "@baphy/dora",
  "version": "1.1.0",
  "description": "DORA metrics calculator — Deployment Frequency, Lead Time, Change Failure Rate, MTTR",
  "license": "MIT",
  "author": "pilmee <pilmee@gmail.com>",
  "homepage": "https://github.com/ElJijuna/baphy#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElJijuna/baphy.git",
    "directory": "packages/dora"
  },
  "bugs": {
    "url": "https://github.com/ElJijuna/baphy/issues"
  },
  "keywords": [
    "dora",
    "metrics",
    "devops",
    "deployment",
    "lead-time",
    "mttr",
    "engineering-performance"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "vitest": "3.2.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
