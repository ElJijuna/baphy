{
  "name": "baphy",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "npm run lint && npm run format:check && npm run markdownlint && npm run stylelint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "bench": "turbo run bench",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "markdownlint": "markdownlint \"**/*.md\" --ignore node_modules",
    "stylelint": "stylelint \"**/*.{css,scss}\" --ignore-pattern \"docs/api/**\" --ignore-pattern \"**/dist/**\" --ignore-pattern \"**/coverage/**\" --allow-empty-input",
    "docs": "typedoc --options typedoc.json",
    "commitlint": "commitlint --from HEAD~1 --to HEAD --verbose"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@semantic-release/changelog": "7.0.0",
    "@semantic-release/git": "11.0.1",
    "@vitest/coverage-v8": "4.1.10",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "eslint": "^10.7.0",
    "markdownlint": "0.41.1",
    "markdownlint-cli": "^0.49.1",
    "semantic-release": "^25.0.8",
    "stylelint": "17.14.1",
    "stylelint-config-standard": "40.0.0",
    "super-configs": "^1.19.0",
    "turbo": "2.10.6",
    "typedoc": "0.28.20",
    "typescript": "7.0.2"
  }
}
